build/
out/
.gradle/
*.class
*.jar
*.aar
*.iml

# Gradle wrapper JAR is small, deterministic, and must be checked in so
# fresh clones can run ./gradlew without installing Gradle first.
!gradle/wrapper/gradle-wrapper.jar

