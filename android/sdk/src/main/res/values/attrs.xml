<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="polst_theme">
        <enum name="system" value="0" />
        <enum name="light" value="1" />
        <enum name="dark" value="2" />
    </attr>
    <attr name="polst_accent" format="color" />
    <attr name="polst_size">
        <enum name="compact" value="0" />
        <enum name="standard" value="1" />
        <enum name="large" value="2" />
    </attr>
    <attr name="polst_hideTitle" format="boolean" />
    <attr name="polst_hideBrand" format="boolean" />
    <attr name="polst_shortId" format="string" />

    <declare-styleable name="PolstWidgetView">
        <attr name="polst_shortId" />
        <attr name="polst_theme" />
        <attr name="polst_accent" />
        <attr name="polst_size" />
        <attr name="polst_hideTitle" />
        <attr name="polst_hideBrand" />
    </declare-styleable>
</resources>
